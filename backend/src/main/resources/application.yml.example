spring:
  application:
    name: ballix

  datasource:
    url: jdbc:mysql://localhost:3306/ballix?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

football:
  api:
    key: YOUR_FOOTBALL_DATA_API_KEY   # https://www.football-data.org 에서 발급
    base-url: https://api.football-data.org/v4

server:
  port: 8080
